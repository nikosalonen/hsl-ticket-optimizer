{
  "name": "hsl-ticket-optimizer",
  "private": true,
  "version": "1.0.0",
  "description": "HSL public transport ticket cost optimizer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@vitest/ui": "^4.1.9",
    "daisyui": "^5.6.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "hsl",
    "public-transport",
    "ticket",
    "optimizer",
    "helsinki"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
